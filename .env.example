PORT=3000
NODE_ENV=production          # use "production" on Railway
API_KEY=                     # generate with: openssl rand -hex 32

# Sync scrape: max wait before HTTP 504 (ms); default ~110s (under typical Clay HTTP limits)
SCRAPE_SYNC_TIMEOUT_MS=110000
# Max concurrent POST /api/scrape executions (Playwright is heavy — keep low)
MAX_CONCURRENT_SCRAPES=3

# --- Health endpoints (see README.md) ---
# GET /api/health  → liveness (Railway healthcheckPath)
# GET /api/ready   → readiness

S3_ENDPOINT=                 # optional — leave empty if not using S3
S3_BUCKET=                   # optional — leave empty if not using S3
S3_ACCESS_KEY=               # optional — leave empty if not using S3
S3_SECRET_KEY=               # optional — leave empty if not using S3
DEFAULT_MAX_DEPTH=3
DEFAULT_MAX_PAGES=50
PAGE_TIMEOUT_MS=30000
# Crawler internal cap (partial results); align with SCRAPE_SYNC_TIMEOUT_MS for HTTP clients
JOB_TIMEOUT_MS=110000
REQUEST_DELAY_MS=1500
BROWSER_CONCURRENCY=3
